# ReckonBot Environment Configuration
# Copy this file to .env and adjust the values for your deployment.

# ===========================
# Flask Server Configuration
# ===========================
FLASK_APP=app.py
FLASK_DEBUG=1
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000
SECRET_KEY=super-secret-reckonbot-key

# ===========================
# Dashboard & Build Config
# ===========================
BUILD_ID=dev-2026-05-11
CONTENT_MAX_WIDTH=1280

# ===========================
# Telemetry & API keys
# ===========================
# Define a pre-shared key for hardware to safely ingest telemetry. Leave blank to disable.
INGEST_API_KEY=my-secure-hardware-key
TELEMETRY_STALE_SECONDS=15

# ===========================
# Camera Proxy Configuration
# ===========================
# Set to 1 to enable the backend to proxy the MJPEG stream, 0 to bypass.
CAMERA_PROXY_ENABLE=0
CAMERA_HOST=http://10.54.239.150
